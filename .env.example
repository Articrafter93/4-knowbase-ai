# ──────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────
POSTGRES_USER=knowbase
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=knowbase
DATABASE_URL=postgresql+asyncpg://knowbase:changeme_strong_password@postgres:5432/knowbase

# ──────────────────────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────────
# QDRANT
# ──────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ──────────────────────────────────────────────────────────────
# JWT / SECURITY
# ──────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_strong_256bit_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ──────────────────────────────────────────────────────────────
# AI / LLM (OpenAI — swap provider here if needed)
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_PRIMARY_MODEL=gpt-4o
LLM_ROUTING_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ──────────────────────────────────────────────────────────────
# INGESTION SETTINGS
# ──────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# ──────────────────────────────────────────────────────────────
# RAG RETRIEVAL
# ──────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=6
RETRIEVAL_BACKEND=pgvector   # pgvector | qdrant | hybrid

# ──────────────────────────────────────────────────────────────
# FRONTEND
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="KnowBase"
